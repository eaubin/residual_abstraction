# caches & local environments
__pycache__/
.mypy_cache/
.venv*/
.devcontainer/

# historical snapshots and superseded runs (not part of the record)
archive/
*.zip

# heavy regenerable artifacts: cache.npz is rebuilt deterministically from
# registered run commands. New model checkpoints are also untracked by
# default; track a model.pt only when a registration/review explicitly marks
# that run non-reproducible without the checkpoint.
*.npz
out/*/model.pt
.venv
